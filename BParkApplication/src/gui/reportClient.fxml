<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.ReportClientGUI" spacing="10" alignment="TOP_CENTER" prefWidth="400" prefHeight="300">
    <children>
        <ComboBox fx:id="reportTypeCombo" prefWidth="200" />
        <Button text="Generate Report" onAction="#generateReport" />
        <Button text="Get All Parking Status" onAction="#getAllParkingStatus" />
        <TextArea fx:id="reportDisplay" prefHeight="200" editable="false" />
    </children>
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>
</VBox> 