<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="350" prefWidth="506.0" spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.UserManagementScreen">
    <children>
        <Label text="User ID:" />
        <TextField fx:id="userIdField" />
        <Button onAction="#searchUser" text="Search User" />
        <Button onAction="#checkOrder" text="View Orders" />
        <Button onAction="#generateReport" text="Generate Report" />
        <Label fx:id="resultLabel" />
      <TableView fx:id="table" prefHeight="200.0" prefWidth="200.0" />
    </children>
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
</VBox>
