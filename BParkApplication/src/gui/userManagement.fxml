<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.UserManagementScreen" spacing="10" alignment="TOP_CENTER" prefWidth="400" prefHeight="350">
    <children>
        <Label text="User ID:" />
        <TextField fx:id="userIdField" />
        <Button text="Search User" onAction="#searchUser" />
        <Button text="Check Order" onAction="#checkOrder" />
        <Button text="Generate Report" onAction="#generateReport" />
        <Label fx:id="resultLabel" />
        <TextArea fx:id="logArea" prefHeight="200" editable="false" />
    </children>
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>
</VBox> 